---
import type { StoreBusiness } from '@/lib/api';

interface Props {
  business: StoreBusiness;
  branchCount?: number;
}

const { business, branchCount = 1 } = Astro.props;
---

<header class="sticky top-0 z-40">
  <!-- Banner con color de marca -->
  <div class="h-1" style={`background: var(--brand-color)`}></div>

  <div class="bg-white dark:bg-neutral-900 border-b border-gray-100 dark:border-neutral-800">
    <div class="max-w-6xl mx-auto px-4 py-4">
      <div class="flex items-center gap-3">
        <!-- Logo -->
        {business.logo ? (
          <div class="shrink-0">
            <img
              src={business.logo}
              alt={business.name}
              class="w-11 h-11 rounded-xl object-cover ring-2 ring-gray-100 dark:ring-neutral-800"
            />
          </div>
        ) : (
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-white text-lg font-bold shrink-0" style={`background: var(--brand-color)`}>
            {business.name.charAt(0)}
          </div>
        )}

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <h1 class="text-base font-bold text-gray-900 dark:text-neutral-100 truncate">{business.name}</h1>
          {business.description ? (
            <p class="text-xs text-gray-500 dark:text-neutral-500 truncate">{business.description}</p>
          ) : business.address && (
            <p class="text-xs text-gray-500 dark:text-neutral-500 truncate">📍 {business.address}</p>
          )}
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-1.5">
          <a
            href="/favorites"
            class="flex items-center justify-center w-9 h-9 rounded-xl bg-gray-50 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400 hover:bg-gray-100 dark:hover:bg-neutral-700 transition-colors"
            aria-label="Favoritos"
          >
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </a>

          {branchCount > 1 && (
            <a
              href="/info"
              class="flex items-center justify-center w-9 h-9 rounded-xl bg-gray-50 dark:bg-neutral-800 text-gray-500 dark:text-neutral-400 hover:bg-gray-100 dark:hover:bg-neutral-700 transition-colors"
              aria-label="Sucursales"
            >
              <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </a>
          )}

          {business.phone && business.dial_code && (
            <a
              href={`https://wa.me/${(business.dial_code + business.phone).replace(/[^0-9]/g, '')}`}
              target="_blank"
              rel="noopener"
              class="flex items-center justify-center w-9 h-9 rounded-xl bg-gray-50 dark:bg-neutral-800 text-green-600 dark:text-green-500 hover:bg-gray-100 dark:hover:bg-neutral-700 transition-colors"
              aria-label="WhatsApp"
            >
              <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</header>
