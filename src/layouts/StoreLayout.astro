---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  color?: string;
  logo?: string | null;
}

const { title, description, color = '#3499f8', logo } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || title} />
    <link rel="icon" type="image/svg+xml" href={logo || '/favicon.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="view-transition" content="same-origin" />
    <title>{title}</title>
    <style define:vars={{ brandColor: color, brandColorDark: color + 'dd' }}>
      :root {
        --brand-color: var(--brandColor);
        --brand-color-dark: var(--brandColorDark);
      }
    </style>
  </head>
  <body class="bg-gray-50 dark:bg-neutral-950 min-h-screen transition-colors">
    <slot />
  </body>
</html>
